# =============================
# ADMIN CREDENTIALS
# =============================
ADMIN_BOOTSTRAP_EMAIL=admin@yourdomain.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeThisSecurePassword123
ADMIN_BOOTSTRAP_NAME=Administrateur

# =============================
# FLASK CONFIGURATION
# =============================
FLASK_SECRET_KEY=change-me-to-a-random-secure-key-in-production
PORT=5000

# =============================
# DATABASE CONFIGURATION
# =============================
# IMPORTANT: Par défaut SQLite (local). Pour une BD distante, utiliser DATABASE_URL
#
# Exemples:
# PostgreSQL: postgresql://user:password@host:5432/dbname
# MySQL:      mysql+pymysql://user:password@host:3306/dbname
# SQLite:     sqlite:///./base_donnees.sqlite (défaut)

DATABASE_URL=
# Sinon utiliser DB_PATH pour SQLite local:
DB_PATH=base_donnees.sqlite

# =============================
# EMAIL SMTP CONFIGURATION
# ⚠️ À CONFIGURER: voir EMAIL_CONFIG.md pour les instructions
# =============================
MAIL_ENABLED=1
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=your_real_email@gmail.com
MAIL_SMTP_PASSWORD=your_app_specific_password
MAIL_SMTP_USE_TLS=1
MAIL_SMTP_USE_SSL=0
MAIL_FROM_EMAIL=your_real_email@gmail.com
CONTACT_EMAIL=contact@example.com

# =============================
# SESSION CONFIGURATION
# =============================
SESSION_TYPE=filesystem
SESSION_KEY_PREFIX=dgs:session:
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=0

# =============================
# RATE LIMITING & REDIS (Optional)
# =============================
REDIS_URL=
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_STRATEGY=fixed-window

# =============================
# CAPTCHA CONFIGURATION (hCaptcha)
# =============================
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# =============================
# FILE UPLOAD CONFIGURATION
# =============================
MAX_UPLOAD_MB=5

# =============================
# CHAT CONFIGURATION
# =============================
CHAT_WS_URL=

