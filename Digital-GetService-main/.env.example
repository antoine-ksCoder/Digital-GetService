# =============================
# ADMIN CREDENTIALS
# =============================
ADMIN_BOOTSTRAP_EMAIL=admin@yourdomain.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeThisSecurePassword123
ADMIN_BOOTSTRAP_NAME=Administrateur

# =============================
# FLASK CONFIGURATION
# =============================
FLASK_SECRET_KEY=change-me-to-a-random-secure-key-in-production
PORT=5000

# =============================
# DATABASE CONFIGURATION
# =============================
DATABASE_URL=
DB_PATH=base_donnees.sqlite

# =============================
# EMAIL SMTP CONFIGURATION
# =============================
MAIL_ENABLED=1
MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=your_email@example.com
MAIL_SMTP_PASSWORD=your_app_password
MAIL_SMTP_USE_TLS=1
MAIL_SMTP_USE_SSL=0
MAIL_FROM_EMAIL=no-reply@example.com
CONTACT_EMAIL=contact@example.com

# =============================
# SESSION CONFIGURATION
# =============================
SESSION_TYPE=filesystem
SESSION_KEY_PREFIX=dgs:session:
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=0

# =============================
# RATE LIMITING & REDIS (Optional)
# =============================
REDIS_URL=
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_STRATEGY=fixed-window

# =============================
# CAPTCHA CONFIGURATION (hCaptcha)
# =============================
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# =============================
# FILE UPLOAD CONFIGURATION
# =============================
MAX_UPLOAD_MB=5

# =============================
# CHAT CONFIGURATION
# =============================
CHAT_WS_URL=
